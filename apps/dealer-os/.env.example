# Commissioned 41 OS — environment variables
# Copy to .env.local for local dev, and set the same keys in Vercel for production.
# Never commit real keys. .env.local is gitignored.

# --- Supabase (all three required for login + the shared store to work) ---
# From Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=PASTE_SUPABASE_PUBLISHABLE_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=PASTE_SUPABASE_SERVICE_ROLE_SECRET_HERE

# --- ILA (the AI assistant) — REQUIRED for ILA chat, coaching, scans, parsing ---
# From console.anthropic.com. Without this, every ILA feature is dark.
ANTHROPIC_API_KEY=PASTE_ANTHROPIC_API_KEY_HERE

# --- ILA's voice (OPTIONAL) — text-to-speech via ElevenLabs ---
# From elevenlabs.io. If unset, ILA still works in text; she just won't speak.
ELEVENLABS_API_KEY=

# --- Billing (OPTIONAL until you turn on paid signup) — Stripe checkout ---
# From dashboard.stripe.com. Only needed once self-serve billing is live.
STRIPE_SECRET_KEY=
# The Stripe Price ID the checkout button charges (price_...). Needed with the key.
STRIPE_PRICE_ID=

# --- Nightly End-of-Day Brief (REQUIRED for the scheduled brief) ---
# A long random string you invent. Vercel Cron sends it as the Authorization
# bearer so only Vercel can trigger the nightly run. In production the cron
# endpoint FAILS CLOSED (503) until this is set — so the brief won't run without
# it, but it also can't be triggered by anyone else. Must match vercel.json cron.
CRON_SECRET=

# --- Email (OPTIONAL) — waitlist / report delivery via Resend ---
# From resend.com. If unset, emails are simply skipped.
RESEND_API_KEY=
EMAIL_FROM=notifications@yourdealership.com

# --- ILA shared brain (OPTIONAL) — cross-product learning store ---
# If set, ILA's learned lessons sync to the shared Commissioned 41 brain so every
# product's ILA gets smarter together. If unset, ILA still learns locally per app.
ILA_BRAIN_URL=
ILA_BRAIN_KEY=

# --- Owner / admin control ---
# The email you (the owner) will SIGN IN with on the live app. This account can
# assign every other employee's role from the Admin > Owner Access Control panel.
# Get this wrong and no one can administer the app on launch day.
NEXT_PUBLIC_OWNER_EMAIL=owner@yourdealership.com
# Optional: extra owner emails, comma-separated.
NEXT_PUBLIC_OWNER_EMAILS=

# --- Rate limiting (STRONGLY recommended for production) ---
# Protects the AI + public endpoints from cost abuse. Create a free Upstash Redis
# database (upstash.com) and paste its REST URL + token here and in Vercel.
# These give you a PRECISE, distributed cap shared across all serverless
# instances. If they're UNSET, limiting still runs via an always-on in-memory
# fallback (it never fully fails open) — but that floor is PER-INSTANCE, so on
# serverless it's a weaker cap, not a global one. Set these for real protection.
# Set them and the distributed limiter turns on automatically — no code change,
# no redeploy needed.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
