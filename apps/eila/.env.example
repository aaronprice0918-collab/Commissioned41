# Mission OS Lite — environment variables.
# Copy to .env.local for local dev; set these in Vercel for production.

# --- Cloud sync (Supabase) — optional ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Billing (Stripe) — required to take payments ---
# 1) In Stripe, create a Product "Mission OS Lite" with a recurring price of
#    $19.99/month. Copy that price's ID (looks like price_xxx) into STRIPE_LITE_PRICE_ID.
# 2) Copy your Stripe Secret key (sk_live_... for real charges, sk_test_... to test)
#    into STRIPE_SECRET_KEY.
# Without these, /subscribe shows "Billing isn't configured yet" and no charges occur.
STRIPE_SECRET_KEY=
STRIPE_LITE_PRICE_ID=
