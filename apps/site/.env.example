# Commissioned 41 brand site — environment variables.
# Copy to .env.local and fill in. Everything here is OPTIONAL: the site works
# with sensible defaults, and the contact/join forms fall back to a local JSONL
# file when storage + email aren't configured.

# --- Product URLs (the two product properties) -------------------------------
# Brand rule: every product lives on its OWN SUBDOMAIN of commissioned41.com.
# Defaults below follow that pattern. Override here / in Vercel to repoint a
# product without a code change.
# NEXT_PUBLIC_MISSION_OS_LITE_URL=https://lite.commissioned41.com
# NEXT_PUBLIC_DEALER_MISSION_OS_URL=https://missionos.commissioned41.com/login

# --- Supabase (durable storage for signups + contact messages) ---------------
# Reuse the MissionOS Supabase project or a new one. Suggested tables:
#   create table mission_signups (
#     email text primary key, source text, created_at timestamptz default now()
#   );
#   create table contact_messages (
#     id bigint generated always as identity primary key,
#     name text, email text, interest text, message text, source text,
#     created_at timestamptz default now()
#   );
# Use the SERVICE ROLE key (server-only — never expose to the client).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional table-name overrides:
# MISSION_LIST_TABLE=mission_signups
# CONTACT_TABLE=contact_messages

# --- Resend (welcome email + contact notifications) --------------------------
# Verify the commissioned41.com domain in Resend, then set:
RESEND_API_KEY=
EMAIL_FROM=Commissioned 41 <mission@commissioned41.com>
# Where inbound contact-form messages are forwarded:
CONTACT_TO=aaronpricemeta@gmail.com
